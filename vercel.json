{
  "version": 2,
  "public": true,
  "buildCommand": "pip install -r requirements.txt",
  "env": {
    "FLASK_ENV": "production"
  },
  "functions": {
    "api/app.py": {
      "runtime": "python3.12"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/app.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
